# ─────────────────────────────────────────────────────────────
# 이 파일을 복사해서 .env.local 을 만들고 값을 채우세요.
#   cp .env.local.example .env.local
# .env.local 은 절대 커밋되지 않습니다(.gitignore 에 포함).
# Vercel 배포 시에는 이 값들을 Vercel 프로젝트 > Settings > Environment Variables 에 넣습니다.
# ─────────────────────────────────────────────────────────────

# [서버 전용] Claude(Anthropic) API 키 — 브라우저에 절대 노출되지 않음 (API 라우트에서만 사용)
# https://console.anthropic.com/ 에서 발급
# 키가 없으면 앱은 자동으로 "데모(샘플) 계획"을 반환합니다. (개발/미리보기용)
ANTHROPIC_API_KEY=

# [클라이언트 공개] Supabase 연결 정보 — 나중에 Vercel 에 이 두 값을 넣으면 저장 기능이 켜집니다.
# Supabase 프로젝트 > Settings > API 에서 확인
# 비워두면 "계획 저장" 기능만 비활성화되고 나머지는 정상 동작합니다.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
